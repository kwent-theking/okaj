{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "ESNext",
    "outDir": "dist",
    "sourceMap": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2015", "ES2016", "ES2017", "ES2018", "ES2019", "ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "target": "ES6"
  },
  "include": ["src/**/*"]
}
